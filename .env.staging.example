# ── Environment ───────────────────────────────────────────────
ENV=staging

# ── Application image ────────────────────────────────────────
APP_IMAGE=ghcr.io/tu-usuario/ductifact:staging

# ── Database ─────────────────────────────────────────────────
DB_USER=ductifact_staging_user
DB_PASSWORD=CHANGE_ME_different_from_prod
DB_NAME=ductifact_staging_db

# ── Application ──────────────────────────────────────────────
APP_HOST=localhost
APP_PORT=8091
JWT_SECRET=CHANGE_ME_different_from_prod
JWT_TOKEN_DURATION=15m
JWT_REFRESH_TOKEN_DURATION=168h
# Frontend origins allowed to call this API.
# Add http://localhost to allow frontend devs on any port.
CORS_ORIGINS=https://ductifact-staging.jcapsule.work,http://localhost
LOG_LEVEL=debug
LOG_FORMAT=json
GIN_MODE=release

# ── Rate limiting ─────────────────────────────────────────────
RATE_LIMIT_IP_MAX=200
RATE_LIMIT_IP_WINDOW=1m
RATE_LIMIT_USER_MAX=120
RATE_LIMIT_USER_WINDOW=1m

# ── Login throttle ───────────────────────────────────────────
LOGIN_THROTTLE_MAX_ATTEMPTS=10
LOGIN_THROTTLE_WINDOW=15m
LOGIN_THROTTLE_LOCKOUT=15m

# ── MinIO (S3-compatible object storage) ─────────────────────
# Use different credentials from production
MINIO_ROOT_USER=CHANGE_ME_different_from_prod
MINIO_ROOT_PASSWORD=CHANGE_ME_different_from_prod
MINIO_BUCKET=ductifact-staging
MINIO_CONSOLE_PORT=9001

# ── SMTP (email) ─────────────────────────────────────────────
# Use a staging-only sender; consider MailPit or sandbox mode.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_AUTH=true
SMTP_USERNAME=CHANGE_ME
SMTP_PASSWORD=CHANGE_ME
SMTP_FROM=noreply@ductifact-staging.jcapsule.work

# ── Monitoring ───────────────────────────────────────────────
GRAFANA_PORT=3001

PROMETHEUS_RETENTION=15d
