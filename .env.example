# ── Environment ───────────────────────────────────────────────
# Set according to target: local | staging | prod
ENV=local

# ── Application images (local only) ───────────────────────────
# Used only by ./scripts/deploy.sh local
BACKEND_IMAGE=backend-app
FRONTEND_IMAGE=frontend-app

# ── Shared platform images ─────────────────────────────────────
POSTGRES_IMAGE=postgres:15-alpine@sha256:CHANGE_ME
MINIO_IMAGE=minio/minio:RELEASE.2025-04-08T15-41-24Z@sha256:CHANGE_ME
REDIS_IMAGE=redis:7-alpine@sha256:CHANGE_ME
PROMETHEUS_IMAGE=prom/prometheus:v3.3.0@sha256:CHANGE_ME
GRAFANA_IMAGE=grafana/grafana:11.6.0@sha256:CHANGE_ME

# ── Frontend ──────────────────────────────────────────────────
FRONTEND_PORT=4200

# ── Database ──────────────────────────────────────────────────
DB_USER=ductifact
DB_PASSWORD=SECRET_IN_GITHUB_ENV
DB_NAME=ductifact

# ── Backend ───────────────────────────────────────────────────
BACKEND_HOST=localhost
BACKEND_PORT=8080
JWT_SECRET=SECRET_IN_GITHUB_ENV
JWT_TOKEN_DURATION=15m
JWT_REFRESH_TOKEN_DURATION=168h
# Frontend origins allowed to call this API (comma-separated)
CORS_ORIGINS=*
LOG_LEVEL=debug
LOG_FORMAT=text
GIN_MODE=debug

# ── Rate limiting ─────────────────────────────────────────────
RATE_LIMIT_IP_MAX=10000
RATE_LIMIT_IP_WINDOW=1m
RATE_LIMIT_USER_MAX=10000
RATE_LIMIT_USER_WINDOW=1m

# ── Login throttle ────────────────────────────────────────────
LOGIN_THROTTLE_MAX_ATTEMPTS=100
LOGIN_THROTTLE_WINDOW=1m
LOGIN_THROTTLE_LOCKOUT=1m

# ── MinIO (S3-compatible object storage) ─────────────────────
MINIO_ROOT_USER=SECRET_IN_GITHUB_ENV
MINIO_ROOT_PASSWORD=SECRET_IN_GITHUB_ENV
MINIO_BUCKET=ductifact
MINIO_CONSOLE_PORT=9001

# ── SMTP (email) ──────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_AUTH=false
SMTP_USERNAME=SECRET_IN_GITHUB_ENV
SMTP_PASSWORD=SECRET_IN_GITHUB_ENV
SMTP_FROM=noreply@ductifact.local

# ── Redis (distributed state) ─────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_AUTH=true
REDIS_PASSWORD=SECRET_IN_GITHUB_ENV
REDIS_DB=0

# ── Monitoring ────────────────────────────────────────────────
GRAFANA_PORT=3000
PROMETHEUS_RETENTION=7d

# ── One-time tokens ───────────────────────────────────────────
VERIFICATION_BASE_URL=http://localhost:3000
VERIFICATION_EMAIL_TOKEN_TTL=24h
VERIFICATION_PASSWORD_RESET_TOKEN_TTL=1h
