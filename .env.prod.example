# ── Environment ─────────────────────────────────────────────
ENV=prod

# ── Images ───────────────────────────────────────────────────
# Images are managed in environments/production.manifest.env
FRONTEND_PORT=3000

# ── Database ────────────────────────────────────────────────
DB_USER=ductifact_user
DB_PASSWORD=CHANGE_ME_generate_with_openssl_rand_-base64_24
DB_NAME=ductifact_db

# ── Backend ────────────────────────────────────────────────
BACKEND_HOST=localhost
BACKEND_PORT=8090
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_-base64_32
JWT_TOKEN_DURATION=15m
JWT_REFRESH_TOKEN_DURATION=168h
CORS_ORIGINS=https://ductifact.jcapsule.work
LOG_LEVEL=info
LOG_FORMAT=json
GIN_MODE=release

# ── Rate limiting ────────────────────────────────────────────
RATE_LIMIT_IP_MAX=100
RATE_LIMIT_IP_WINDOW=1m
RATE_LIMIT_USER_MAX=60
RATE_LIMIT_USER_WINDOW=1m

# ── Login throttle ──────────────────────────────────────────
LOGIN_THROTTLE_MAX_ATTEMPTS=5
LOGIN_THROTTLE_WINDOW=15m
LOGIN_THROTTLE_LOCKOUT=30m

# ── MinIO (S3-compatible object storage) ─────────────────────
# Generate strong credentials: openssl rand -base64 24
MINIO_ROOT_USER=CHANGE_ME_generate_with_openssl_rand_-base64_24
MINIO_ROOT_PASSWORD=CHANGE_ME_generate_with_openssl_rand_-base64_24
MINIO_BUCKET=ductifact
MINIO_CONSOLE_PORT=9000

# ── SMTP (email) ─────────────────────────────────────────────
# Configure a real SMTP provider (e.g. SendGrid, SES).
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_AUTH=true
SMTP_USERNAME=apikey
SMTP_PASSWORD=CHANGE_ME_use_real_api_key
SMTP_FROM=noreply@ductifact.jcapsule.work

# ── Redis (distributed state) ────────────────────────────────
# Enable AUTH in production. Generate password: openssl rand -base64 24
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_AUTH=true
REDIS_PASSWORD=CHANGE_ME_generate_with_openssl_rand_-base64_24
REDIS_DB=0

# ── Monitoring ──────────────────────────────────────────────
GRAFANA_PORT=3000
PROMETHEUS_RETENTION=30d

# ── One-time tokens ──────────────────────────────────────────
VERIFICATION_BASE_URL=https://ductifact.jcapsule.work
VERIFICATION_EMAIL_TOKEN_TTL=24h
VERIFICATION_PASSWORD_RESET_TOKEN_TTL=1h
