# ── Environment ───────────────────────────────────────────────
ENV=local

# ── Application image ────────────────────────────────────────
# Use the image built by backend's `make docker-build`
APP_IMAGE=backend-app

# ── Database ─────────────────────────────────────────────────
DB_USER=ductifact
DB_PASSWORD=ductifact
DB_NAME=ductifact

# ── Application ──────────────────────────────────────────────
APP_PORT=8080
JWT_SECRET=local-dev-secret-not-for-production
CORS_ORIGINS=*
LOG_LEVEL=debug
LOG_FORMAT=text
GIN_MODE=debug

# ── Monitoring ───────────────────────────────────────────────
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=7d