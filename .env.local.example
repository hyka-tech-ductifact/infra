# ── Environment ───────────────────────────────────────────────
ENV=local

# ── Application image ────────────────────────────────────────
# Use the image built by backend's `make docker-build`
APP_IMAGE=backend-app

# ── Database ─────────────────────────────────────────────────
DB_USER=ductifact
DB_PASSWORD=ductifact
DB_NAME=ductifact

# ── Application ──────────────────────────────────────────────
APP_HOST=localhost
APP_PORT=8080
JWT_SECRET=local-dev-secret-not-for-production
JWT_TOKEN_DURATION=15m
JWT_REFRESH_TOKEN_DURATION=168h
CORS_ORIGINS=*
LOG_LEVEL=debug
LOG_FORMAT=text
GIN_MODE=debug

# ── Rate limiting ─────────────────────────────────────────────
RATE_LIMIT_IP_MAX=10000
RATE_LIMIT_IP_WINDOW=1m
RATE_LIMIT_USER_MAX=10000
RATE_LIMIT_USER_WINDOW=1m

# ── Login throttle ───────────────────────────────────────────
LOGIN_THROTTLE_MAX_ATTEMPTS=100
LOGIN_THROTTLE_WINDOW=1m
LOGIN_THROTTLE_LOCKOUT=1m

# ── MinIO (S3-compatible object storage) ─────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=ductifact
MINIO_CONSOLE_PORT=9001

# ── SMTP (email) ─────────────────────────────────────────────
# In local development, point to MailPit (captures all emails).
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_AUTH=false
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@ductifact.local

# ── Monitoring ───────────────────────────────────────────────
GRAFANA_PORT=3000
PROMETHEUS_RETENTION=7d

# ── One-time tokens ───────────────────────────────────────────
VERIFICATION_BASE_URL=http://localhost:3000
VERIFICATION_EMAIL_TOKEN_TTL=24h
VERIFICATION_PASSWORD_RESET_TOKEN_TTL=1h
