ENV=production
# ── Production Runtime Config (non-sensitive) ────────────────
# Versioned in Git. Sensitive values are injected in CI from
# GitHub Environment secrets during deploy.
# ──────────────────────────────────────────────────────────────

ENV=prod

# ── Frontend ──────────────────────────────────────────────────
FRONTEND_PORT=4200

# ── Database ──────────────────────────────────────────────────
DB_USER=ductifact_user
DB_PASSWORD=SECRET_IN_GITHUB_ENV
DB_NAME=ductifact_db

# ── Backend ───────────────────────────────────────────────────
BACKEND_HOST=localhost
BACKEND_PORT=8090
JWT_SECRET=SECRET_IN_GITHUB_ENV
JWT_TOKEN_DURATION=15m
JWT_REFRESH_TOKEN_DURATION=168h
# Frontend origins allowed to call this API (comma-separated)
CORS_ORIGINS=https://ductifact.jcapsule.work
LOG_LEVEL=info
LOG_FORMAT=json
GIN_MODE=release

# ── Rate limiting ─────────────────────────────────────────────
RATE_LIMIT_IP_MAX=100
RATE_LIMIT_IP_WINDOW=1m
RATE_LIMIT_USER_MAX=60
RATE_LIMIT_USER_WINDOW=1m

# ── Login throttle ────────────────────────────────────────────
LOGIN_THROTTLE_MAX_ATTEMPTS=5
LOGIN_THROTTLE_WINDOW=15m
LOGIN_THROTTLE_LOCKOUT=30m

# ── MinIO (S3-compatible object storage) ─────────────────────
MINIO_ROOT_USER=SECRET_IN_GITHUB_ENV
MINIO_ROOT_PASSWORD=SECRET_IN_GITHUB_ENV
MINIO_BUCKET=ductifact
MINIO_CONSOLE_PORT=9000

# ── SMTP (email) ──────────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_AUTH=true
SMTP_USERNAME=SECRET_IN_GITHUB_ENV
SMTP_PASSWORD=SECRET_IN_GITHUB_ENV
SMTP_FROM=noreply@ductifact.jcapsule.work

# ── Redis (distributed state) ─────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_AUTH=true
REDIS_PASSWORD=SECRET_IN_GITHUB_ENV
REDIS_DB=0

# ── Monitoring ────────────────────────────────────────────────
GRAFANA_PORT=3000
PROMETHEUS_RETENTION=30d

# ── One-time tokens ───────────────────────────────────────────
VERIFICATION_BASE_URL=https://ductifact.jcapsule.work
VERIFICATION_EMAIL_TOKEN_TTL=24h
VERIFICATION_PASSWORD_RESET_TOKEN_TTL=1h